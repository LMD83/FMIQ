{
  "name": "charity-cloud",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "convex dev",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "seed": "convex run seed:run",
    "smoke": "node scripts/smoke-golden-path.mjs"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@convex-dev/auth": "0.0.94",
    "convex": "1.41.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@edge-runtime/vm": "5.0.0",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "20.19.7",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "convex-test": "0.0.53",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
