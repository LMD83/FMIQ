# Convex — from dashboard (Settings → URL & Deploy Key)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.eu-west-1.convex.cloud
CONVEX_DEPLOYMENT=prod:your-deployment
# HTTP actions base URL (shown beside Cloud URL in dashboard)
CONVEX_SITE_URL=https://your-deployment.eu-west-1.convex.site

# AI providers (set on deployment via `npx convex env set`, not in .env.local)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Cloudflare R2 (set on deployment via `npx convex env set`)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=verifiq-prod-eu-west
# R2_PUBLIC_URL=
