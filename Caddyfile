# VerifIQ marketing site — Caddy static server.
# Binds to the platform-provided $PORT (Railway, Render, Fly), 8080 locally.
{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode gzip

	# Allow extensionless URLs: /about -> /about.html
	try_files {path} {path}.html {path}/index.html

	file_server

	# Custom 404 page.
	handle_errors {
		@404 expression {http.error.status_code} == 404
		handle @404 {
			rewrite * /404.html
			file_server
		}
	}
}
