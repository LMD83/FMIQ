{
  "name": "@fmiq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:start": "node scripts/start-postgres.mjs",
    "db:setup": "node scripts/setup-db.mjs",
    "db:up": "node scripts/db-up.mjs",
    "db:reset": "node scripts/reset-db.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.6.1",
    "fast-json-stringify": "^5.16.1",
    "fastify": "^4.28.1",
    "jose": "^5.9.6",
    "papaparse": "^5.4.1",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "embedded-postgres": "^18.4.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
