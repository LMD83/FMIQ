# API config
PORT=8080
DATABASE_URL=postgresql://fmiq_app:fmiq_app@localhost:5432/fmiq

# Set true for local dev: injects a dev tenant + ConservationOfficer role, skips Entra.
DEV_NO_AUTH=true
DEV_TENANT_ID=00000000-0000-0000-0000-0000000000a1
DEV_USER_ID=00000000-0000-0000-0000-0000000000b1

# Azure Entra ID (used when DEV_NO_AUTH=false)
ENTRA_TENANT_ID=common
ENTRA_API_AUDIENCE=api://fmiq-api
# JWKS + issuer are derived from tenant for the common/multitenant endpoint
